Rasm2DApplication()
.run(main);

fn main(rend: Rasm2DRenderer) {
    rend.openFont(testResource("DejaVuSerif.ttf"), 20, fn(font) {
        rend.render(
            fn(graphics) {  
                graphics.renderText(font, "Hello world", RGBAColor(255, 0, 0, 355), 300, 250);
            });
    });
    sdlDelay(2000);
}

