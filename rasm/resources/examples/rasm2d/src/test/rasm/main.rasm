initRasm2D(fn(rasm2d) {
    rasm2d.createWindow("Hello world", 100, 100, 800, 600, fn(window) {
        window.createRenderer(render);
    });
});

fn render(rend: Rasm2DRenderer) {
    initRasm2DTTF(
        fn(ttf) {  
            ttf.openFont(testResource("DejaVuSerif.ttf"), 20, fn(font) {
                renderText(rend, font, "Hello world", RGBAColor(255, 0, 0, 355), 300, 250);

                rend.present();
                sdlDelay(2000);
            });
        });
}