pub struct Rect2D {
    x: int,
    y: int,
    w: int,
    h: int
}

pub struct RGBAColor {
    r: int,
    g: int,
    b: int,
    a: int
}

pub struct Rasm2DRenderer {
    private rend: SDLRenderer
}

pub struct Rasm2DWindow {
    private win: SDLWindow
}

pub struct Rasm2DGraphics {
    private rend: SDLRenderer
}

pub fn initRasm2D(handler: fn(Rasm2D) -> ()) {
    Rasm2D().match(fn(rasm2d) {
        handler(rasm2d);
        rasm2d.close();
    }, fn(error) {
        println(error);
        exitMain(1);
    });
}

fn close(rasm2d: Rasm2D) {
    sdlQuit();
}

pub fn createWindow(rasm2d: Rasm2D, title: str, x: int, y: int, width: int, height: int, handler: fn(Rasm2DWindow) -> ()) {
    let window = rasm2d.createWindow(title, x, y, width, height);
    handler(window);
    window.close();
}

pub fn createRenderer(window: Rasm2DWindow, handler: fn(Rasm2DRenderer) -> ()) {
    let renderer = window.createRenderer();
    handler(renderer);
    renderer.close();
}

fn present(graphics: Rasm2DGraphics) {
    sdlRenderPresent(graphics.rend);
}

fn createWindow(rasm2D: Rasm2D, title: str, x: int, y: int, width: int, height: int) -> Rasm2DWindow {
    Rasm2DWindow(sdlCreateWindow(title, x, y, width, height));
}

fn close(window: Rasm2DWindow) {
    sdlDestroyWindow(window.win);
}

fn createRenderer(window: Rasm2DWindow) -> Rasm2DRenderer {
    Rasm2DRenderer(sdlCreateRenderer(window.win));
}

fn close(rend: Rasm2DRenderer) {
    sdlDestroyRenderer(rend.rend);
}

pub fn createGraphics(rend: Rasm2DRenderer, handler: fn(Rasm2DGraphics) -> ()) {
    let graphics = Rasm2DGraphics(rend.rend);
    handler(graphics);
    graphics.present();
}

