fn rasm2DInit() -> Option<str> /{
    int error = $call(sdlInit);
    if (error != 0) {
        struct RasmPointer_* error = $call(sdlGetError);
        return $call(Some, error: str);
    }
    error = $call(ttfInit);
    if (error != 0) {
        struct RasmPointer_* error = $call(sdlGetError);
        return $call(Some, error: str);
    }
    return $enumSimple(None);
}/