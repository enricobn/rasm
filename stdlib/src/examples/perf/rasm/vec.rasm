pub fn vecSuite() -> TestSuite {
    TestSuite("Vec")
    .add("foldleft", foldLeft);
}

fn foldLeft() -> Assertions {
    let v = vecRange(1, 10000)
        .map(fn(it) { Some(it);})
        .filter(fn(it) { it.match(fn(i) { true;}, { false;});});

    let v1 = v.foldLeft(
        Vec<Option<int>>(), 
        fn(accum, actual) {  
            accum.push(actual);
        }
    );
        
    Assertions().assertEquals(9999, v1.len);
}