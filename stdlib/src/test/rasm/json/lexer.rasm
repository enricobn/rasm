pub fn jsonLexerSuite() -> TestSuite {
    TestSuite("json lexer")
    .add("testLexer", testStringLexer)
    .add("testNumberLexer", testNumberLexer)
    .add("testFileLexer", testFileLexer);
}

fn testStringLexer() -> Assertions {
    let tokensResult = lexe("\"Hello world\"");

    tokensResult(tokensResult, 
        fn(assertions, tokens) {  
            assertions.assertEquals("[JsonToken(String(Hello world))]", tokens.toString);
        }
    );
}

fn testNumberLexer() -> Assertions {
    let tokensResult = lexe("1234.67");
    tokensResult(tokensResult, 
        fn(assertions, tokens) {  
            assertions.assertEquals("[JsonToken(Number(1234.67))]", tokens.toString);
        }
    );
}

fn testFileLexer() -> Assertions {
    let s = readFile(fromRasmSourceFolder("test/resources/small.json"));
    let tokensResult = lexe(s);
    tokensResult(tokensResult, 
        fn(assertions, tokens) {
            // println();
            //println(tokens.noSpaces);
            assertions.assertEquals(74, tokens.len);
        }
    );
}

fn tokensResult(t: Result<Vec<JsonToken>, str>, a: fn(Assertions, Vec<JsonToken>) -> Assertions) -> Assertions {
    t.match(
        fn(tokens) {  
            a(Assertions(), tokens);
        }, 
        fn(err) {  
            Assertions().fail(err);
        });
}