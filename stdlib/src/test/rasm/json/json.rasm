@json()
pub struct AStruct<T> {
    x: int,
    y: int,
    v: T
}

@json()
pub enum Message<T> {
    Ping,                               // Unit variant (no parameters)
    Pong,                               // Unit variant
    Request(body: str),                 // Variant with one parameter
    Response(status: int, data: T)      // Variant with more parameters
}